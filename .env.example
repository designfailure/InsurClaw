# Copy to `.env` and adjust. Never commit `.env`.

# --- PostgreSQL (docker-compose.yml) ---
POSTGRES_DB=insurclaw
POSTGRES_USER=insurclaw
# Required for any non-local deployment; change the default below for dev.
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# Connection strings (pick one context):

# From another container on the same Docker Compose network (future gateway service):
# DATABASE_URL=postgresql://insurclaw:changeme@postgres:5432/insurclaw

# From the host (psql, app running outside Docker) — use the password above:
DATABASE_URL=postgresql://insurclaw:changeme@127.0.0.1:5432/insurclaw

# --- Optional: OpenClaw (Phase 2 — see docker/README.md) ---
# Paths on the host for bind mounts into the OpenClaw gateway container:
# OPENCLAW_CONFIG_DIR=${HOME}/.openclaw-config-insurclaw
# OPENCLAW_WORKSPACE_DIR=/absolute/path/to/insurclaw
# OPENCLAW_GATEWAY_PORT=18789
# OPENCLAW_BRIDGE_PORT=18790
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_IMAGE=openclaw:local
# OPENCLAW_TZ=Europe/Paris
