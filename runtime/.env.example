# InsurClaw Runtime - Environment Variables
# Copy to .env and fill in values

# Slack (required for primary channel)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...  # Optional: for Socket Mode

# Anthropic (required for Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Database (optional - defaults to ./data/insurclaw.db)
INSURCLAW_DB_PATH=./data/insurclaw.db

# here.now (optional — permanent publishes; without key, publish.sh uses anonymous 24h sites)
HERENOW_API_KEY=

# Admin WhatsApp (optional - for admin push notifications)
# Comma-separated phone numbers with country code
ADMIN_WHATSAPP_IDS=+1234567890
